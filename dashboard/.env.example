# -----------------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# See docs/SALESFORCE_SETUP.md for step-by-step instructions.
# -----------------------------------------------------------------

# -- Consolidated Server-to-Server ECA (Client Credentials Flow) ---------
# Single ECA used by Models API, Account Summary Agent MCP, and Agentforce
# Agent API. Scopes: api, sfap_api, mcp_api, einstein_gpt_api, scrt_api.
# When set, these take precedence over the per-integration vars below.
SF_SERVER_CLIENT_ID=
SF_SERVER_CLIENT_SECRET=

# -- Salesforce External Client App credentials -------------------
# Create these in Salesforce Setup > App Manager > New Connected App
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here
SF_LOGIN_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:3000/api/auth/callback

# -- Anthropic API key --------------------------------------------
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- Session cookie encryption ------------------------------------
# Generate a random secret with: openssl rand -base64 32
SESSION_SECRET=generate_a_random_32_character_string_here

# -- AI providers -- all optional ---------------------------------

# Local MCP -- set to 'false' to hide the Local provider in the AI panel
LOCAL_MCP_ENABLED=true

# Salesforce-hosted MCP server URL
# Leave blank to hide the Hosted provider from the AI panel
SF_MCP_SERVER_URL=

# If Hosted MCP requires its own OAuth (separate from main SF session):
SF_MCP_CLIENT_ID=
SF_MCP_CALLBACK_URL=

# Salesforce Models API (Trust Layer / Einstein) -- required for the Trust Layer provider
# Create an External Client App with Client Credentials flow in Salesforce Setup.
# The token is fetched from SF_LOGIN_URL and used against api.salesforce.com.
SF_MODELS_CLIENT_ID=
SF_MODELS_CLIENT_SECRET=
# Optionally override the default model (sfdc_ai__DefaultBedrockAnthropicClaude46Sonnet)
SF_MODELS_DEFAULT_MODEL=

# Agentforce -- all three required to enable the Agentforce provider
# Leave blank to hide Agentforce from the AI panel
SF_AGENT_CLIENT_ID=
SF_AGENT_CLIENT_SECRET=

# Default agent ID to seed the first agent profile.
# Additional agents can be configured in Settings → AI provider.
SF_AGENT_ID=

# Optional: fallback agent for the "Consult Agentforce" tool in Claude mode.
# SF_AGENT_ID is used by default. Set this only to point the consult tool at a
# different agent than the one used in Agentforce mode.
SF_AGENTFORCE_CONSULT_AGENT_ID=

# -- Local MCP server path (optional) ---------------------------------
# Absolute path to the compiled salesforce-mcp-server index.js.
# Defaults to the sibling salesforce-mcp-server/dist/index.js when unset.
# MCP_SERVER_PATH=/path/to/salesforce-mcp-server/dist/index.js

# -- MCP transport mode (optional) ------------------------------------
# 'local' (default) uses the stdio MCP server above.
# 'hosted' uses the Salesforce-hosted MCP server at SF_MCP_SERVER_URL.
# MCP_MODE=local

# -- Account Summary Agent MCP (opt-in parallel Hosted MCP) ----------
# A second Hosted MCP server that exposes an Agentforce agent as MCP tools.
# Uses Client Credentials Flow — no PKCE; the agent runs under a fixed Run As user.
# Set ENABLED=true to merge this MCP's tools into the Hosted mode tool list.
# Defaults to false so existing Hosted behavior is preserved when unset.
SF_MCP_ACCOUNT_AGENT_ENABLED=false
SF_MCP_ACCOUNT_AGENT_CLIENT_ID=
SF_MCP_ACCOUNT_AGENT_CLIENT_SECRET=
SF_MCP_ACCOUNT_AGENT_SERVER_URL=https://api.salesforce.com/platform/mcp/v1/custom/Account_Summary_Agent

# -- Debug (optional) -------------------------------------------------
# Set to 'true' to log raw Agentforce API responses to the server console.
# Useful for diagnosing structured response handling issues.
AGENTFORCE_DEBUG=false
