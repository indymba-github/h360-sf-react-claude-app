# ── Salesforce External Client App ───────────────────────────────────────────
# Found in Setup → External Client Apps → your app → OAuth Settings

SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Base login URL. Use https://test.salesforce.com for sandboxes.
SF_LOGIN_URL=https://login.salesforce.com

# OAuth callback. Must be registered in your External Client App.
# Local dev:
SF_CALLBACK_URL=http://localhost:3000/api/auth/callback
# Production (Vercel):
# SF_CALLBACK_URL=https://your-app.vercel.app/api/auth/callback

# ── Anthropic ────────────────────────────────────────────────────────────────
# https://console.anthropic.com — generate an API key under your workspace

ANTHROPIC_API_KEY=

# ── Session encryption ────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=

# ── MCP server mode ───────────────────────────────────────────────────────────
# "local"  — spawns the bundled salesforce-mcp-server as a stdio child process (default)
# "hosted" — connects to a remote Salesforce Hosted MCP Server via StreamableHTTP

MCP_MODE=local

# Local mode only: override the path to the compiled MCP server.
# Defaults to ../salesforce-mcp-server/dist/index.js relative to process.cwd().
#
# MCP_SERVER_PATH=/absolute/path/to/salesforce-mcp-server/dist/index.js

# Hosted mode only: URL of the remote Salesforce Hosted MCP Server endpoint.
# Required when MCP_MODE=hosted.
#
# SF_MCP_SERVER_URL=https://api.salesforce.com/platform/mcp/v1/custom/sfmcpdashboard
