# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────
# This MCP server uses the Salesforce OAuth 2.0 JWT Bearer flow.
# Run scripts/generate-cert.sh to create your RSA key pair, then
# upload the generated server.crt to your Salesforce Connected App.
# ─────────────────────────────────────────────────────────────

# Salesforce org login URL (use https://test.salesforce.com for sandboxes)
SF_LOGIN_URL=https://login.salesforce.com

# Consumer Key from your Salesforce Connected App
SF_CLIENT_ID=your_consumer_key_here

# Salesforce username the JWT will authenticate as
SF_USERNAME=your_sf_username@example.com

# Path to the RSA private key generated by scripts/generate-cert.sh
SF_PRIVATE_KEY_PATH=./server.key

# Optional: proactive token refresh threshold in minutes (default: 55)
# Set lower if your org's session timeout is under 1 hour
# SF_TOKEN_LIFETIME_MINUTES=55
